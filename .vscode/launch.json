{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Fortran Debug (GDB)",
      "type": "cppdbg",
      "request": "launch",
      //"program": "${workspaceFolder}/build/main",
      //"program": "${workspaceFolder}/build/src/libs/integral_generator/tests/integrator_test",
      //"program": "${workspaceFolder}/build/src/libs/integral_generator/tests/integration_path_part_custom_curve_test",
      "program": "${workspaceFolder}/build/src/libs/integral_generator/tests/integrator_custom_curve_test",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
