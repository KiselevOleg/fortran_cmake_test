    N = 60
    res = 0d0
    associate(dx => (b - a) / N)
      associate(x => [(a + dx * (i - 1), i = 1, N + 1)])
        do i = 1, N
          res = res + element%run(func = func, a = x(i), b = x(i + 1))
        end do
      end associate
    end associate

    call assertEqual(&
      expected = (3d0, 0d0), &
      actual = res, &
      tolerance = 1d-9, &
      message = "incorrect result" &
    )

    contains

    complex(dp) function func(x) result(res)
    implicit none(type, external)
      real(dp), intent(in) :: x

      res = sin(x) + exp(- x * 2d1) * 2d1
    end function func
  end subroutine integration_element_gauss4_test

