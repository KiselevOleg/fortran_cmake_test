  pure complex(dp) function get_norm(curve, scale, a, b, x, dx) result(res)
  implicit none (type, external)
    interface
      pure real(dp) function curve(x)
      import :: dp
      implicit none (type, external)
        real(dp), intent(in) :: x
      end function curve
    end interface
    real(dp), intent(in) :: scale
    complex(dp), intent(in) :: a
    complex(dp), intent(in) :: b
    real(dp), intent(in) :: x
    real(dp), intent(in) :: dx

    associate(n => (b - a) / abs(b - a))
      res = cmplx(dx * abs(b - a), (curve(x + dx) - curve(x)) * scale, dp)
      res = res / real(res)
      if (aimag(n) >= 0d0) then
        res = res * exp(log(n))
      else
        res = res * exp(log(n) + (0d0, 3.14159265358979d0) * 2d0)
      end if
    end associate
  end function get_norm

  pure complex(dp) function norm_number(x) result(res)
  implicit none (type, external)
    complex(dp), intent(in) :: x

    res = x / abs(x)
  end function norm_number





