@test
module assert_test
use system___assert, only: error_assert, error_not_assert, &
  warning_assert, warning_not_assert, &
  equals
use PFUnit, only: &
  assertEqual, & ! assertEqual(expected, actual, [tolerance], [message])
  assertNotEqual, & ! assertNotEqual(expected, actual, [tolerance], [message])
  assertTrue ! assertTrue(condition, [message])
use, intrinsic :: iso_fortran_env, only: sp => real32, dp => real64, qp => real128, &
  i1 => int8, i2 => int16, i4 => int32, i8 => int64
implicit none (type, external)
public

  character(len = *), parameter :: module_name = "system___assert_test"

contains

  @test
  subroutine error_assert_test_common()
  implicit none (type, external)
    call error_assert(location = module_name // ".error_not_assert_test_common", &
      message = "error_assert has thrown an exception incorrectly", &
      condition = 1_i1 == 0_i1 + 1_i1 &
    )
    call error_assert(location = module_name // ".error_not_assert_test_common", &
      message = "error_assert has thrown an exception incorrectly", &
      condition = 1_i1 > 0_i1 &
    )
    call error_assert(location = module_name // ".error_not_assert_test_common", &
      message = "error_assert has thrown an exception incorrectly", &
      condition = .true. &
    )
  end subroutine error_assert_test_common
  @test
  subroutine error_not_assert_test_common()
  implicit none (type, external)
    call error_not_assert(location = module_name // ".error_not_assert_test_common", &
      message = "error_assert has thrown an exception incorrectly", &
      condition = 1_i1 /= 0_i1 + 1_i1 &
    )
    call error_not_assert(location = module_name // ".error_not_assert_test_common", &
      message = "error_assert has thrown an exception incorrectly", &
      condition = 1_i1 == 0_i1 &
    )
    call error_not_assert(location = module_name // ".error_not_assert_test_common", &
      message = "error_assert has thrown an exception incorrectly", &
      condition = .false. &
    )
  end subroutine error_not_assert_test_common

  @test
  subroutine equals_test_common()
  implicit none (type, external)
    call assertEqual(.true., equals(1d0, 1d0, 1d-9))
    call assertEqual(.true., equals(1d0, 1.000011d0, 1d-3))
    call assertEqual(.true., equals(1d0, 1.000011d0, 1d-4))
    call assertEqual(.false., equals(1d0, 1.000011d0, 1d-5))

    call assertEqual(.true., equals((1d0, 1d0), (1d0, 1d0), 1d-9))
    call assertEqual(.true., equals((1d0, 1d0), (1.000011d0, 1d0), 1d-3))
    call assertEqual(.true., equals((1d0, 1d0), (1.000011d0, 1d0), 1d-4))
    call assertEqual(.false., equals((1d0, 1d0), (1.000011d0, 1d0), 1d-5))
    call assertEqual(.false., equals((1d0, 1d0), (1d0, 0d0), 1d-5))
  end subroutine equals_test_common





  @before
  subroutine BeforeAll()
  implicit none (type, external)
    print *, "srart tests"
  end subroutine BeforeAll

  @after
  subroutine AfterAll()
  implicit none (type, external)
    print *, "end tests"
  end subroutine AfterAll
end module assert_test
